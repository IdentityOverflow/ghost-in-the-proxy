# Default provider key (used when model not matched in map)
DEFAULT_PROVIDER=ollama


# Map incoming model -> provider:model
# Example: {"gpt-4o-mini":"openai:gpt-4o-mini","llama3.1":"openrouter:meta-llama/llama-3.1-8b-instruct"}
MODEL_MAP={}


# Providers (fill only those you use)
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=sk-...


OPENROUTER_BASE_URL=https://openrouter.ai/api
OPENROUTER_API_KEY=or-...


AZURE_OPENAI_BASE_URL=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=az-...
AZURE_OPENAI_API_VERSION=2024-08-01-preview


LMSTUDIO_BASE_URL=http://localhost:1234/v1


# If your Ollama (or gateway) exposes OpenAI /v1
OLLAMA_BASE_URL=http://localhost:11434/v1